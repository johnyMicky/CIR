# .env.example

# Vercel Environment Detection (Automatically set by Vercel)
VERCEL=1
VERCEL_ENV=production

# Node Environment
NODE_ENV=production

# Port for local development
PORT=3000

# Gemini API Key (Optional - for AI features)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Supabase Configuration (Optional - for persistent database)
# Get these at: https://supabase.com/
SUPABASE_URL=
SUPABASE_ANON_KEY=
